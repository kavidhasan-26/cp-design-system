{
  "name": "cp-design-system",
  "version": "0.1.0",
  "description": "CP design system — React Native components and tokens",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    }
  },
  "files": [
    "src/components",
    "src/fonts",
    "src/tokens",
    "src/index.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "expo-font": ">=12.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.74.0",
    "react-native-svg": ">=15.0.0"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-docs": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-storysource": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@storybook/theming": "^8.6.18",
    "@types/react": "^19.0.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "^0.79.2",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.20.0",
    "storybook": "^8.6.18",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "keywords": [
    "design-system",
    "react-native",
    "expo",
    "tokens"
  ],
  "license": "UNLICENSED"
}
